# Copy to .env and fill in your own values
OPENROUTER_API_KEY=

OLLAMA_HOST=http://localhost:11434

# Small local model (Ollama)
SMALL_MODEL=llama3.1:8b

# Default large model used when no routing is performed yet
LARGE_MODEL=anthropic/claude-sonnet-4.5

# Pool of large models the router can pick from (OpenRouter slugs).
# Verify availability at https://openrouter.ai/models
LARGE_MODEL_REASONING=openai/gpt-5
LARGE_MODEL_CHAT=anthropic/claude-sonnet-4.5
LARGE_MODEL_FAST=google/gemini-2.5-flash
LARGE_MODEL_CODE=anthropic/claude-sonnet-4.5

# Escalate to the large model when the small model's confidence is below this.
CONFIDENCE_THRESHOLD=0.7
