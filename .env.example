# Copy to .env and fill in your own values
OPENROUTER_API_KEY=

OLLAMA_HOST=http://localhost:11434

# Small local model (Ollama)
SMALL_MODEL=llama3.1:8b

# Default large model used when no routing is performed yet
LARGE_MODEL=anthropic/claude-sonnet-4.5

# Pool of large models the router can pick from (OpenRouter slugs).
# Verify availability at https://openrouter.ai/models
LARGE_MODEL_REASONING=openai/gpt-5
LARGE_MODEL_CHAT=anthropic/claude-sonnet-4.5
LARGE_MODEL_FAST=google/gemini-2.5-flash
LARGE_MODEL_CODE=anthropic/claude-sonnet-4.5

# Escalate to the large model when the small model's confidence is below this.
CONFIDENCE_THRESHOLD=0.7

# When escalating, condense prompts longer than this many characters with the
# small model before sending them to the large model. Set to 0 to disable.
CONDENSE_THRESHOLD_CHARS=4000

# Set to 1 to enable the embedding-based paraphrase cache (slower writes,
# faster reads on repeat questions).
SEMANTIC_CACHE=0

# Cosine similarity above which a semantic cache lookup counts as a hit.
# Tuned for llama3.1 chat-model embeddings; raise it if you switch to a
# dedicated embedding model like nomic-embed-text.
SEMANTIC_THRESHOLD=0.75
